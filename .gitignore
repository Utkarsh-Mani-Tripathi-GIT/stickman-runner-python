# ═══════════════════════════════════════════════════════════════
#  Stickman Runner — Git Ignore
# ═══════════════════════════════════════════════════════════════

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual Environments ──────────────────────────────────
venv/
env/
.venv/
.env/

# ─── Distribution / Packaging ─────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ─── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Logs / Temp ───────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
